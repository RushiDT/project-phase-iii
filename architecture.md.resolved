    end

    subgraph "Backend Layer — Laptop"
        SERVER["🖥️ Central Server<br/>index.js (JWT/HTTPS)<br/>Port 5002"]
        ML["🧠 ML Engine<br/>anomaly_detector.py<br/>Port 5001"]
        BC["⛓️ Blockchain<br/>DeviceLog.sol<br/>Ganache Port 7545"]
    end

    subgraph "Presentation Layer"
        DASH["📊 Dashboard<br/>App.jsx (React+Vite)<br/>Port 5173"]
    end

    ESP32 -- "MQTT Publish (TLS)<br/>iot/data" --> MQTT
    ESP8266 -- "MQTT Publish (TLS)<br/>iot/data" --> MQTT
    SIM -- "MQTT Publish (TLS)<br/>iot/data" --> MQTT
    MQTT -- "Subscribe<br/>iot/data" --> GW
    GW -- "HTTPS POST (JWT)<br/>/api/logs (Batch)" --> SERVER
    GW -- "HTTPS POST (JWT)<br/>/api/alerts" --> SERVER
    SERVER -- "HTTPS POST<br/>/predict" --> ML
    SERVER -- "Python CLI<br/>log_event()" --> BC
    ML -- "Python Import<br/>log_to_blockchain()" --> BC
    DASH -- "HTTPS GET (JWT)<br/>/api/logs, /api/health" --> SERVER
    DASH -- "WebSocket (WSS)<br/>Real-time Updates" --> SERVER
    DASH -- "HTTPS POST (JWT)<br/>/api/control" --> SERVER
    SERVER -- "HTTPS POST<br/>/control" --> GW
    GW -- "MQTT Publish (TLS)<br/>iot/control/{id}" --> MQTT
